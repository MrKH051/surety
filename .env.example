# ---- Server ----
PORT=3100

# ---- Payment rail: "sim" (offline demo) or "croo" (real CROO Agent Protocol on Base) ----
RAIL=sim

# ---- AI brain (any OpenAI-compatible endpoint) ----
# Easiest free option: install Ollama (https://ollama.com), `ollama pull llama3.1`,
# and the defaults below just work. Works without any brain too (heuristic mode).
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
LLM_API_KEY=

# ---- CROO (only needed when RAIL=croo) ----
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
# CROO_RPC_URL=

# Surety's SDK key (one agent profile: sells 3 services, buys specialists)
CROO_SURETY_SDK_KEY=

# The serviceIds of Surety's three listed services on the CROO Agent Store
CROO_INSURE_SERVICE_ID=
CROO_CLAIM_SERVICE_ID=
CROO_CERTIFICATE_SERVICE_ID=

# Display-only starting float shown on the dashboard in croo mode
CROO_START_BALANCE=25

# ---- Product pricing (USDC). In croo mode make these match your store listing. ----
INSURE_PRICE=0.05
CLAIM_PRICE=0.01
CERTIFICATE_PRICE=0.05

# ---- Underwriting & claims ----
SEED_CAPITAL=5
MAX_COVERAGE=1.0
POLICY_HOURS=24
MIN_PAYOUT_CONFIDENCE=0.5

# ---- Hiring third-party specialists from the store ----
EXTERNAL_HIRES=on
VERIFIER_MAX_PRICE=0.1
TRUST_MAX_PRICE=0.1
PAYOUT_MAX_PRICE=0.1
# Comma-separated agentIds of our own sibling agents (never self-trade)
EXTERNAL_EXCLUDE_AGENT_IDS=
# Optionally pin exact store serviceIds (otherwise discovered by keyword)
VERIFIER_SERVICE_ID=
TRUST_SERVICE_ID=
PAYOUT_SERVICE_ID=
